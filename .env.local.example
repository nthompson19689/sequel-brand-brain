NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Powers src/lib/embeddings.ts (text-embedding-3-small, 1536 dims) used
# for semantic search across articles, brand_docs, battle_cards,
# call_insights, campaigns, campaign_assets, competitor_scan_results.
OPENAI_API_KEY=
# Shared secret protecting POST /api/embed/backfill (bypasses auth
# middleware so it can be triggered from a terminal/cron). Generate
# with: openssl rand -hex 32
EMBED_BACKFILL_SECRET=
# Vercel Cron auth — Vercel sends this as `Authorization: Bearer <value>`
# on every cron invocation. Generate with: openssl rand -hex 32
# Cron routes refuse the request if this is set and the bearer doesn't match.
CRON_SECRET=
# Fathom call recording integration. Get the API key from
# https://fathom.video/settings/integrations. The webhook secret is
# the value Fathom signs payloads with — paste the same value into
# Fathom's webhook config.
FATHOM_API_KEY=
FATHOM_WEBHOOK_SECRET=
VOYAGE_API_KEY=
WEBFLOW_API_KEY=
WEBFLOW_COLLECTION_ID=
WEBFLOW_SITE_ID=

# LinkedIn post scraping (Fresh LinkedIn Scraper API via RapidAPI)
# Sign up at https://rapidapi.com/freshdata-freshdata-default/api/fresh-linkedin-profile-data
RAPIDAPI_KEY=
